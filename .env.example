ANTHROPIC_API_KEY=sk-ant-...
SECRET_KEY=troque-por-uma-string-aleatoria-longa
ADMIN_USERNAME=seu_usuario
ADMIN_PASSWORD=sua_senha_segura

# URL pública do app — usada nos links do feed RSS
PUBLIC_BASE_URL=https://audifaz.seudominio.com

# Open Notebook (geração de podcast)
# Gere com: openssl rand -base64 32
OPEN_NOTEBOOK_ENCRYPTION_KEY=troque-por-32-bytes-base64
# Gere com: openssl rand -base64 24
SURREAL_PASSWORD=troque-por-senha-forte
# API key do Google AI Studio (https://aistudio.google.com) — free tier do Gemini 2.5 TTS
GEMINI_API_KEY=...
# Preencher após criar o notebook "AudiFaz" pela UI do open-notebook (http://localhost:8502)
OPENNOTEBOOK_NOTEBOOK_ID=notebook:...
# Nome do Episode Profile criado pela UI (default: audifaz)
OPENNOTEBOOK_EPISODE_PROFILE=audifaz
